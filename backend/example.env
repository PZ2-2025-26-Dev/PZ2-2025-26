DB_ROOT_PWD=password
DB_NAME=app_db
DB_USER=user
DB_PWD=password
PZ_DATABASE_URL=mysql+pymysql://user:password@db:3306/app_db
PZ_DEBUG=1

# Konfiguracja CORS dla FastAPI - dozwolone originy frontendu i nagłówki requestów.
PZ_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]
PZ_CORS_HEADERS=["*"]